{
  "name": "ux-tracker",
  "version": "0.1.0",
  "type": "module",
  "description": "UX Tracker — lightweight usability session recording framework",
  "scripts": {
    "build": "node build.js",
    "build:prod": "cross-env NODE_ENV=production node build.js",
    "build:watch": "node build.js --watch",
    "dev": "concurrently \"node build.js --watch\" \"npx serve .\"",
    "lint": "npx eslint src/"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.0",
    "html2canvas": "^1.4.1"
  },
  "devDependencies": {
    "concurrently": "latest",
    "cross-env": "latest",
    "esbuild": "latest"
  }
}
